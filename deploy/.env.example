# Copy to .env in this directory: cp .env.example .env
#
# Kafka's advertised listener address. Since producer/consumer run as
# containers on the same "dataload" compose network as kafka-1, the
# container's own hostname works and is the simplest correct value:
KAFKA_LISTENER_IP=kafka-1

# If you instead need to reach Kafka from outside docker (e.g. a host-side
# kafkactl/kcat for debugging), set this to the host machine's LAN IP or
# 127.0.0.1 instead, and connect producer/consumer to that same address.

# PostgreSQL credentials, applied only on first init of an empty
# deploy/data/postgres/ (changing these later requires wiping that directory
# or running ALTER ROLE/ALTER DATABASE by hand). If you change them, update
# the DSN in cmd/consumer/config.yml (postgres.dsn) to match.
POSTGRES_DB=beaver
POSTGRES_USER=beaver
POSTGRES_PASSWORD=beaver
